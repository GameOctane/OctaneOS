#!/bin/sh
# OctaneOS init: install dev SSH key to the correct path.
# Root home in Batocera is /userdata/system — Dropbear looks there for
# authorized_keys, not /root/.ssh. Runs after S12populateshare.

DEV_KEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIEmEFho+A+VIZNyOogCAiL2ZpGoGFY8v8Fu4/TdwYb4u octaneos-dev"

case "$1" in
  start)
    # Batocera sets root shell to /bin/dash; profile scripts use bash syntax → Bad substitution
    sed -i 's|:/bin/dash$|:/bin/bash|' /etc/passwd

    # S26system falls back to first 2 chars of system.language ("en" from en_US) when
    # system.kblayout is unset. "en" is not a valid loadkeys layout; "us" is correct.
    BATOCERA_CONF=/userdata/system/batocera.conf
    if ! grep -q "^system.kblayout=" "$BATOCERA_CONF" 2>/dev/null; then
        echo "system.kblayout=us" >> "$BATOCERA_CONF"
    fi

    # Disable the ES screensaver. The default screensaver fires after 5 min idle and
    # attempts video playback which hangs the compositor on A733 (no HW video decode).
    # system.screensaver.time=0 → "Never" in the ES UI.
    # system.screensaver.behavior=black → safe fallback if user re-enables.
    if ! grep -q "^system.screensaver.time=" "$BATOCERA_CONF" 2>/dev/null; then
        echo "system.screensaver.time=0" >> "$BATOCERA_CONF"
    fi
    if ! grep -q "^system.screensaver.behavior=" "$BATOCERA_CONF" 2>/dev/null; then
        echo "system.screensaver.behavior=black" >> "$BATOCERA_CONF"
    fi

    # Disable USB autosuspend for the AIC8800 WiFi dongle (VID a69c, PID 8800/8801).
    # The USB core parks the dongle after 2s idle by default; the aic8800 driver does
    # not implement suspend/resume and the kernel hangs trying to communicate with it
    # after it powers down. Force power/control=on so udev never suspends it.
    for dev in /sys/bus/usb/devices/*; do
        vid=$(cat "$dev/idVendor" 2>/dev/null)
        pid=$(cat "$dev/idProduct" 2>/dev/null)
        if [ "$vid" = "a69c" ] && { [ "$pid" = "8800" ] || [ "$pid" = "8801" ]; }; then
            echo on > "$dev/power/control" 2>/dev/null || true
        fi
    done

    # xpad auto_poweroff=Y (BSP default) causes the driver to send a poweroff
    # command to controllers after idle timeout. The modprobe.d option does not
    # apply because xpad loads before the overlayfs modprobe.d is visible.
    # NOTE: do NOT write to /sys/class/leds/xpad*/brightness as a keepalive —
    # that LED OUT packet causes the 8BitDo to disconnect every ~35s.
    echo N > /sys/module/xpad/parameters/auto_poweroff 2>/dev/null || true

    SSH_DIR=/userdata/system/.ssh
    AUTH_KEYS=$SSH_DIR/authorized_keys
    mkdir -p -m 0700 "$SSH_DIR"
    if ! grep -qF "octaneos-dev" "$AUTH_KEYS" 2>/dev/null; then
        echo "$DEV_KEY" >> "$AUTH_KEYS"
        chmod 0600 "$AUTH_KEYS"
    fi
    ;;
esac

exit 0
