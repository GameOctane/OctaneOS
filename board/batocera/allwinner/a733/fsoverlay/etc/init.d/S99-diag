#!/bin/sh
# OctaneOS display diagnostic — runs once per boot, saves to /userdata/diag.txt
# and to the FAT32 boot partition (/dev/mmcblk0p1) so it can be read on any PC.

sleep 50

{
    date
    echo "=== batocera.conf (video/output keys) ==="
    batocera-conf 2>/dev/null | grep -iE "video|output|resolution"
    echo ""
    echo "=== batocera-drminfo ==="
    batocera-drminfo 2>&1
    echo ""
    echo "=== batocera-resolution listOutputs ==="
    batocera-resolution listOutputs 2>&1
    echo ""
    echo "=== running processes ==="
    ps 2>&1 | grep -iE "emulation|batocera|ES|drm"
    echo ""
    echo "=== ES launch stdout ==="
    cat /userdata/system/logs/es_launch_stdout.log 2>/dev/null || echo "(not found)"
    echo ""
    echo "=== ES launch stderr ==="
    cat /userdata/system/logs/es_launch_stderr.log 2>/dev/null || echo "(not found)"
    echo ""
    echo "=== emulationstation.log (last 100 lines) ==="
    tail -100 /userdata/system/logs/emulationstation.log 2>/dev/null || echo "(not found)"
} > /userdata/diag.txt 2>&1

# Also copy to FAT32 boot partition so it's readable on any PC without ext4 tools
if mkdir -p /mnt/bootfat 2>/dev/null; then
    if mount /dev/mmcblk0p1 /mnt/bootfat 2>/dev/null; then
        cp /userdata/diag.txt /mnt/bootfat/diag.txt 2>/dev/null
        umount /mnt/bootfat 2>/dev/null
    fi
fi
